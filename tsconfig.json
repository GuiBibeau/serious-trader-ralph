{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["apps/portal/src/**/*.ts", "packages/*/src/**/*.ts"],
  "exclude": ["node_modules", "apps/portal/.svelte-kit", "apps/portal/build"]
}
