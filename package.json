{
  "name": "serious-trader-ralph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/portal dev",
    "build": "bun run --cwd apps/portal build",
    "start": "bun run --cwd apps/portal start",
    "typecheck": "bun run --cwd packages/ui typecheck && bun run --cwd apps/portal typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "test": "bun run typecheck && bun run --cwd packages/ui test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@playwright/test": "^1.50.0",
    "@types/node": "^25.2.3",
    "turbo": "^2.8.7",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.0"
}
