{
  "name": "serious-trader-ralph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "bin": {
    "ralph": "dist/bin/ralph.js"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:cli": "bun run src/bin/ralph.ts",
    "build": "bun build src/bin/ralph.ts --outdir dist/bin --target node --format esm",
    "start": "bun dist/bin/ralph.js",
    "dev:local": "NEXT_PUBLIC_EDGE_API_BASE=http://127.0.0.1:8888 NEXT_PUBLIC_SITE_URL=http://localhost:3000 bun run dev",
    "gateway": "bun run src/bin/ralph.ts gateway start",
    "gateway:stop": "bun run src/bin/ralph.ts gateway stop",
    "gateway:restart": "bun run src/bin/ralph.ts gateway restart",
    "status": "bun run src/bin/ralph.ts status",
    "autopilot:start": "bun run src/bin/ralph.ts autopilot start",
    "autopilot:stop": "bun run src/bin/ralph.ts autopilot stop",
    "tool": "bun run src/bin/ralph.ts tool",
    "doctor": "bun run src/bin/ralph.ts doctor",
    "update": "bun run src/bin/ralph.ts update",
    "agent:message": "bun run src/bin/ralph.ts agent:message",
    "help": "bun run src/bin/ralph.ts --help",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:integration:worker:live": "RUN_INTEGRATION_TESTS=1 RUN_WORKER_LIVE_TESTS=1 bun test tests/integration/worker_x402_live.integration.test.ts",
    "contracts:loop-a:schemas": "bun run scripts/generate_loop_a_schemas.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "edge:dev": "cd apps/worker && bun run dev",
    "edge:db:migrate:local": "cd apps/worker && bun run db:migrate:local"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@ellipsis-labs/phoenix-sdk": "^2.0.3",
    "@openbook-dex/openbook-v2": "^0.2.10",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "commander": "^14.0.3",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@types/node": "^25.2.3",
    "@types/ws": "^8.18.1",
    "turbo": "^2.8.7",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.0"
}
