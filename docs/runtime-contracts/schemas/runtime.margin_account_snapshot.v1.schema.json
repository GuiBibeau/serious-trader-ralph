{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/runtime/v1/margin_account_snapshot",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "snapshotId": {
      "type": "string",
      "minLength": 1
    },
    "venueKey": {
      "type": "string",
      "minLength": 1
    },
    "accountRef": {
      "type": "string",
      "minLength": 1
    },
    "capturedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "marketTypes": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["spot", "perp", "options", "prediction"]
      }
    },
    "equityQuote": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?$"
    },
    "initHealthQuote": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?$"
    },
    "maintHealthQuote": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?$"
    },
    "initHealthRatioPct": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?$"
    },
    "maintHealthRatioPct": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?$"
    },
    "usedMarginQuote": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?$"
    },
    "freeCollateralQuote": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?$"
    },
    "liquidationBufferPct": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?$"
    },
    "liquidationRiskLevel": {
      "type": "string",
      "enum": ["low", "warning", "critical"]
    },
    "beingLiquidated": {
      "type": "boolean"
    },
    "isOperational": {
      "type": "boolean"
    },
    "positions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "instrumentId": {
            "type": "string",
            "minLength": 1
          },
          "marketType": {
            "type": "string",
            "enum": ["spot", "perp", "options", "prediction"]
          },
          "side": {
            "type": "string",
            "minLength": 1
          },
          "quantityAtomic": {
            "type": "string",
            "pattern": "^-?\\d+(?:\\.\\d+)?$"
          },
          "collateralAtomic": {
            "type": "string",
            "pattern": "^-?\\d+(?:\\.\\d+)?$"
          },
          "notionalQuote": {
            "type": "string",
            "pattern": "^\\d+(?:\\.\\d+)?$"
          },
          "entryPriceQuote": {
            "type": "string",
            "pattern": "^\\d+(?:\\.\\d+)?$"
          },
          "markPriceQuote": {
            "type": "string",
            "pattern": "^\\d+(?:\\.\\d+)?$"
          },
          "unsettledPnlQuote": {
            "type": "string",
            "pattern": "^\\d+(?:\\.\\d+)?$"
          },
          "reduceOnly": {
            "type": "boolean"
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": ["instrumentId", "marketType", "notes"],
        "additionalProperties": false
      }
    },
    "oracles": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "instrumentId": {
            "type": "string",
            "minLength": 1
          },
          "provider": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["healthy", "stale", "unconfident", "halted"]
          },
          "priceQuote": {
            "type": "string",
            "pattern": "^\\d+(?:\\.\\d+)?$"
          },
          "confidencePct": {
            "type": "string",
            "pattern": "^\\d+(?:\\.\\d+)?$"
          },
          "lastUpdatedSlot": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "lastUpdatedAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": ["instrumentId", "provider", "status", "notes"],
        "additionalProperties": false
      }
    },
    "tags": {
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schemaVersion",
    "snapshotId",
    "venueKey",
    "accountRef",
    "capturedAt",
    "marketTypes",
    "equityQuote",
    "initHealthQuote",
    "maintHealthQuote",
    "usedMarginQuote",
    "freeCollateralQuote",
    "liquidationRiskLevel",
    "beingLiquidated",
    "isOperational",
    "positions",
    "oracles",
    "tags"
  ],
  "additionalProperties": false
}
