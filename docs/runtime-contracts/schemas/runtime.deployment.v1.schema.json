{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/runtime/v1/deployment",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "deploymentId": {
      "type": "string",
      "minLength": 1
    },
    "strategyKey": {
      "type": "string",
      "minLength": 1
    },
    "sleeveId": {
      "type": "string",
      "minLength": 1
    },
    "ownerUserId": {
      "type": "string",
      "minLength": 1
    },
    "pair": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "baseMint": {
          "type": "string",
          "minLength": 32,
          "maxLength": 64
        },
        "quoteMint": {
          "type": "string",
          "minLength": 32,
          "maxLength": 64
        }
      },
      "required": ["symbol", "baseMint", "quoteMint"],
      "additionalProperties": false
    },
    "mode": {
      "type": "string",
      "enum": ["shadow", "paper", "live"]
    },
    "state": {
      "type": "string",
      "enum": [
        "draft",
        "shadow",
        "paper",
        "live",
        "paused",
        "killed",
        "archived"
      ]
    },
    "lane": {
      "type": "string",
      "enum": ["safe", "protected", "fast"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "promotedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "pausedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "killedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "policy": {
      "type": "object",
      "properties": {
        "maxNotionalUsd": {
          "type": "string",
          "pattern": "^\\d+(?:\\.\\d+)?$"
        },
        "dailyLossLimitUsd": {
          "type": "string",
          "pattern": "^\\d+(?:\\.\\d+)?$"
        },
        "maxSlippageBps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "maxConcurrentRuns": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "rebalanceToleranceBps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        }
      },
      "required": [
        "maxNotionalUsd",
        "dailyLossLimitUsd",
        "maxSlippageBps",
        "maxConcurrentRuns",
        "rebalanceToleranceBps"
      ],
      "additionalProperties": false
    },
    "capital": {
      "type": "object",
      "properties": {
        "allocatedUsd": {
          "type": "string",
          "pattern": "^\\d+(?:\\.\\d+)?$"
        },
        "reservedUsd": {
          "type": "string",
          "pattern": "^\\d+(?:\\.\\d+)?$"
        },
        "availableUsd": {
          "type": "string",
          "pattern": "^\\d+(?:\\.\\d+)?$"
        }
      },
      "required": ["allocatedUsd", "reservedUsd", "availableUsd"],
      "additionalProperties": false
    },
    "tags": {
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "schemaVersion",
    "deploymentId",
    "strategyKey",
    "sleeveId",
    "ownerUserId",
    "pair",
    "mode",
    "state",
    "lane",
    "createdAt",
    "updatedAt",
    "policy",
    "capital",
    "tags"
  ],
  "additionalProperties": false
}
