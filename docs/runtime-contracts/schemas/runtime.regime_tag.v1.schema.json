{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/runtime/v1/regime_tag",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "regimeTagId": {
      "type": "string",
      "minLength": 1
    },
    "regimeKey": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated"]
    },
    "dimension": {
      "type": "string",
      "enum": ["trend", "volatility", "spread", "liquidity", "funding", "carry"]
    },
    "value": {
      "type": "string",
      "minLength": 1
    },
    "marketType": {
      "type": "string",
      "enum": ["spot", "perp", "options"]
    },
    "venueKeys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assetKeys": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pairSymbols": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sourceFeatureKeys": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "freshnessSloMs": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "maxAllowedDriftBps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "minConfidenceBps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "provenance": {
      "type": "object",
      "properties": {
        "generatedBy": {
          "type": "string",
          "minLength": 1
        },
        "generatedRevision": {
          "type": "string",
          "minLength": 1
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["generatedBy", "generatedAt"],
      "additionalProperties": false
    },
    "datasetSnapshots": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "datasetId": {
            "type": "string",
            "minLength": 1
          },
          "snapshotId": {
            "type": "string",
            "minLength": 1
          },
          "capturedAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
          },
          "uri": {
            "type": "string",
            "minLength": 1
          },
          "contentDigest": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["datasetId", "snapshotId", "capturedAt"],
        "additionalProperties": false
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "tags": {
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schemaVersion",
    "regimeTagId",
    "regimeKey",
    "version",
    "title",
    "summary",
    "status",
    "dimension",
    "value",
    "marketType",
    "venueKeys",
    "assetKeys",
    "pairSymbols",
    "sourceFeatureKeys",
    "freshnessSloMs",
    "maxAllowedDriftBps",
    "minConfidenceBps",
    "provenance",
    "datasetSnapshots",
    "createdAt",
    "updatedAt",
    "tags"
  ],
  "additionalProperties": false
}
