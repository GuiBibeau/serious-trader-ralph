{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/runtime/v1/run",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "deploymentId": {
      "type": "string",
      "minLength": 1
    },
    "runKey": {
      "type": "string",
      "minLength": 1
    },
    "trigger": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["cron", "signal", "rebalance", "operator", "canary"]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "observedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "featureSnapshotId": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["kind", "source", "observedAt"],
      "additionalProperties": false
    },
    "state": {
      "type": "string",
      "enum": [
        "pending",
        "risk_checked",
        "planned",
        "submitted",
        "receipt_pending",
        "reconciled",
        "needs_manual_review",
        "completed",
        "rejected",
        "failed",
        "killed"
      ]
    },
    "plannedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "riskVerdictId": {
      "type": "string",
      "minLength": 1
    },
    "executionPlanId": {
      "type": "string",
      "minLength": 1
    },
    "submitRequestId": {
      "type": "string",
      "minLength": 1
    },
    "receiptId": {
      "type": "string",
      "minLength": 1
    },
    "failureCode": {
      "type": "string",
      "minLength": 1
    },
    "failureMessage": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schemaVersion",
    "runId",
    "deploymentId",
    "runKey",
    "trigger",
    "state",
    "plannedAt",
    "updatedAt"
  ],
  "additionalProperties": false
}
