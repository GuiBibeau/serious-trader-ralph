{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/runtime/v1/strategy_desk_scenario",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "scenarioId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "ownerUserId": {
      "type": "string",
      "minLength": 1
    },
    "strategyKey": {
      "type": "string",
      "minLength": 1
    },
    "thesis": {
      "type": "string",
      "minLength": 1
    },
    "sleeveId": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "enum": [
        "draft",
        "replay_ready",
        "shadow_ready",
        "paper_ready",
        "operator_review",
        "execution_ready",
        "execution_bound",
        "paused",
        "archived"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "reviewedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "activeHandoffId": {
      "type": "string",
      "minLength": 1
    },
    "latestReportId": {
      "type": "string",
      "minLength": 1
    },
    "riskLimits": {
      "type": "object",
      "properties": {
        "maxReservedCapitalUsd": {
          "type": "string",
          "pattern": "^\\d+(?:\\.\\d+)?$"
        },
        "maxGrossExposureUsd": {
          "type": "string",
          "pattern": "^\\d+(?:\\.\\d+)?$"
        },
        "maxNetExposureUsd": {
          "type": "string",
          "pattern": "^\\d+(?:\\.\\d+)?$"
        },
        "maxLegConcentrationBps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "maxVenueFamilyConcentrationBps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "maxDrawdownBps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        }
      },
      "additionalProperties": false
    },
    "legs": {
      "minItems": 1,
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "legId": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "primary_alpha",
              "hedge",
              "inventory",
              "carry",
              "prediction",
              "liquidity",
              "flash_rebalance"
            ]
          },
          "venueKey": {
            "type": "string",
            "minLength": 1
          },
          "intentFamily": {
            "type": "string",
            "enum": [
              "spot_swap",
              "conditional_spot_order",
              "clob_order",
              "perp_order",
              "prediction_order",
              "flash_atomic"
            ]
          },
          "marketType": {
            "type": "string",
            "enum": ["spot", "perp", "options", "prediction"]
          },
          "pair": {
            "type": "object",
            "properties": {
              "symbol": {
                "type": "string",
                "minLength": 1
              },
              "baseMint": {
                "type": "string",
                "minLength": 32,
                "maxLength": 64
              },
              "quoteMint": {
                "type": "string",
                "minLength": 32,
                "maxLength": 64
              },
              "marketType": {
                "default": "spot",
                "type": "string",
                "enum": ["spot", "perp", "options"]
              }
            },
            "required": ["symbol", "baseMint", "quoteMint", "marketType"],
            "additionalProperties": false
          },
          "instrumentId": {
            "type": "string",
            "minLength": 1
          },
          "assetKeys": {
            "minItems": 1,
            "maxItems": 8,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "enabledModes": {
            "minItems": 1,
            "maxItems": 3,
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["shadow", "paper", "live"]
            }
          },
          "sizing": {
            "type": "object",
            "properties": {
              "targetNotionalUsd": {
                "type": "string",
                "pattern": "^\\d+(?:\\.\\d+)?$"
              },
              "maxNotionalUsd": {
                "type": "string",
                "pattern": "^\\d+(?:\\.\\d+)?$"
              },
              "reserveUsd": {
                "type": "string",
                "pattern": "^\\d+(?:\\.\\d+)?$"
              },
              "maxSlippageBps": {
                "type": "integer",
                "minimum": 0,
                "maximum": 10000
              }
            },
            "required": ["targetNotionalUsd"],
            "additionalProperties": false
          },
          "intent": {
            "type": "object",
            "properties": {
              "adapterKey": {
                "type": "string",
                "minLength": 1
              },
              "side": {
                "type": "string",
                "minLength": 1
              },
              "quantityAtomic": {
                "type": "string",
                "pattern": "^\\d+(?:\\.\\d+)?$"
              },
              "collateralAtomic": {
                "type": "string",
                "pattern": "^\\d+(?:\\.\\d+)?$"
              },
              "outcomeId": {
                "type": "string",
                "minLength": 1
              },
              "settlementMint": {
                "type": "string",
                "minLength": 32,
                "maxLength": 64
              },
              "referenceId": {
                "type": "string",
                "minLength": 1
              },
              "borrowLegs": {
                "maxItems": 8,
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "provider": {
                      "type": "string",
                      "minLength": 1
                    },
                    "mint": {
                      "type": "string",
                      "minLength": 32,
                      "maxLength": 64
                    },
                    "amountAtomic": {
                      "type": "string",
                      "pattern": "^\\d+(?:\\.\\d+)?$"
                    }
                  },
                  "required": ["provider", "mint"],
                  "additionalProperties": false
                }
              },
              "params": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {}
              }
            },
            "additionalProperties": false
          },
          "thesis": {
            "type": "string",
            "minLength": 1
          },
          "dependencies": {
            "maxItems": 16,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "tags": {
            "maxItems": 16,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": [
          "legId",
          "label",
          "role",
          "venueKey",
          "intentFamily",
          "marketType",
          "assetKeys",
          "enabledModes",
          "sizing"
        ],
        "additionalProperties": false
      }
    },
    "evidence": {
      "maxItems": 8,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "stage": {
            "type": "string",
            "enum": [
              "replay",
              "backtest",
              "shadow",
              "paper",
              "bounded_execution"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "evidenceRefs": {
            "minItems": 1,
            "maxItems": 32,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "minLength": 1
                },
                "ref": {
                  "type": "string",
                  "minLength": 1
                },
                "notes": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": ["kind", "ref"],
              "additionalProperties": false
            }
          },
          "latestReportId": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["stage", "summary", "evidenceRefs"],
        "additionalProperties": false
      }
    },
    "implementationReferences": {
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["pull_request", "issue", "commit"]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "mergedAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
          },
          "revision": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["kind", "ref"],
        "additionalProperties": false
      }
    },
    "tags": {
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "schemaVersion",
    "scenarioId",
    "title",
    "summary",
    "ownerUserId",
    "strategyKey",
    "thesis",
    "state",
    "createdAt",
    "updatedAt",
    "legs",
    "evidence",
    "implementationReferences",
    "tags"
  ],
  "additionalProperties": false
}
