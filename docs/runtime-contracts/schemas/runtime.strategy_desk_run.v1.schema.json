{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/runtime/v1/strategy_desk_run",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "scenarioRunId": {
      "type": "string",
      "minLength": 1
    },
    "scenarioId": {
      "type": "string",
      "minLength": 1
    },
    "scenarioState": {
      "type": "string",
      "enum": [
        "draft",
        "replay_ready",
        "shadow_ready",
        "paper_ready",
        "operator_review",
        "execution_ready",
        "execution_bound",
        "paused",
        "archived"
      ]
    },
    "runKind": {
      "type": "string",
      "enum": ["replay", "backtest", "shadow", "paper", "promotion_review"]
    },
    "state": {
      "type": "string",
      "enum": [
        "pending",
        "legs_requested",
        "legs_running",
        "collecting_evidence",
        "needs_review",
        "completed",
        "rejected",
        "failed",
        "cancelled"
      ]
    },
    "requestedBy": {
      "type": "string",
      "minLength": 1
    },
    "trigger": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["cron", "signal", "rebalance", "operator", "canary"]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "observedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "featureSnapshotId": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["kind", "source", "observedAt"],
      "additionalProperties": false
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "legRuns": {
      "minItems": 1,
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "legId": {
            "type": "string",
            "minLength": 1
          },
          "stage": {
            "type": "string",
            "enum": [
              "replay",
              "backtest",
              "shadow",
              "paper",
              "bounded_execution"
            ]
          },
          "state": {
            "type": "string",
            "enum": ["pending", "submitted", "completed", "failed", "skipped"]
          },
          "requestRef": {
            "type": "string",
            "minLength": 1
          },
          "runtimeRunId": {
            "type": "string",
            "minLength": 1
          },
          "runtimeDeploymentId": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["legId", "stage", "state"],
        "additionalProperties": false
      }
    },
    "failureCode": {
      "type": "string",
      "minLength": 1
    },
    "failureMessage": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "schemaVersion",
    "scenarioRunId",
    "scenarioId",
    "scenarioState",
    "runKind",
    "state",
    "requestedBy",
    "trigger",
    "createdAt",
    "updatedAt",
    "legRuns"
  ],
  "additionalProperties": false
}
