{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/runtime/v1/execution_plan",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "planId": {
      "type": "string",
      "minLength": 1
    },
    "deploymentId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "mode": {
      "type": "string",
      "enum": ["shadow", "paper", "live"]
    },
    "lane": {
      "type": "string",
      "enum": ["safe", "protected", "fast"]
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    },
    "simulateOnly": {
      "type": "boolean"
    },
    "dryRun": {
      "type": "boolean"
    },
    "slices": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sliceId": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "enum": ["buy", "sell", "rebalance"]
          },
          "inputMint": {
            "type": "string",
            "minLength": 32,
            "maxLength": 64
          },
          "outputMint": {
            "type": "string",
            "minLength": 32,
            "maxLength": 64
          },
          "inputAmountAtomic": {
            "type": "string",
            "pattern": "^\\d+(?:\\.\\d+)?$"
          },
          "minOutputAmountAtomic": {
            "type": "string",
            "pattern": "^\\d+(?:\\.\\d+)?$"
          },
          "notionalUsd": {
            "type": "string",
            "pattern": "^\\d+(?:\\.\\d+)?$"
          },
          "slippageBps": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          }
        },
        "required": [
          "sliceId",
          "action",
          "inputMint",
          "outputMint",
          "inputAmountAtomic",
          "notionalUsd",
          "slippageBps"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schemaVersion",
    "planId",
    "deploymentId",
    "runId",
    "createdAt",
    "mode",
    "lane",
    "idempotencyKey",
    "simulateOnly",
    "dryRun",
    "slices"
  ],
  "additionalProperties": false
}
