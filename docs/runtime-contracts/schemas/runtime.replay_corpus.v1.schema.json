{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/runtime/v1/replay_corpus",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "corpusId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "replayKind": {
      "type": "string",
      "enum": ["feed_gateway_v1", "bar_series_v1", "order_book_l2_v1"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "venueKeys": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assetKeys": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pairSymbols": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "chainKeys": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "datasetSnapshots": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "datasetId": {
            "type": "string",
            "minLength": 1
          },
          "snapshotId": {
            "type": "string",
            "minLength": 1
          },
          "capturedAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
          },
          "uri": {
            "type": "string",
            "minLength": 1
          },
          "contentDigest": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["datasetId", "snapshotId", "capturedAt"],
        "additionalProperties": false
      }
    },
    "fixtureUri": {
      "type": "string",
      "minLength": 1
    },
    "contentDigest": {
      "type": "string",
      "minLength": 1
    },
    "deterministicSeed": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "tags": {
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schemaVersion",
    "corpusId",
    "title",
    "summary",
    "replayKind",
    "createdAt",
    "updatedAt",
    "venueKeys",
    "assetKeys",
    "pairSymbols",
    "chainKeys",
    "datasetSnapshots",
    "tags"
  ],
  "additionalProperties": false
}
