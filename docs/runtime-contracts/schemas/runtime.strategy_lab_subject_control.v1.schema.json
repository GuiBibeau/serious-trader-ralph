{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/runtime/v1/strategy_lab_subject_control",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "subjectKind": {
      "type": "string",
      "enum": ["strategy", "venue", "asset"]
    },
    "subjectKey": {
      "type": "string",
      "minLength": 1
    },
    "liveAllowed": {
      "type": "boolean"
    },
    "killSwitchEnabled": {
      "type": "boolean"
    },
    "disabledReason": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "updatedBy": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "schemaVersion",
    "subjectKind",
    "subjectKey",
    "liveAllowed",
    "killSwitchEnabled",
    "updatedAt"
  ],
  "additionalProperties": false
}
