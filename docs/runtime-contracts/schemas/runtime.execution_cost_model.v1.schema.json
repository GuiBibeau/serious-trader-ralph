{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/runtime/v1/execution_cost_model",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "modelId": {
      "type": "string",
      "minLength": 1
    },
    "venueKey": {
      "type": "string",
      "minLength": 1
    },
    "marketType": {
      "type": "string",
      "enum": ["spot", "perp", "options"]
    },
    "pairSymbol": {
      "type": "string",
      "minLength": 1
    },
    "instrumentId": {
      "type": "string",
      "minLength": 1
    },
    "assetKeys": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "modeCoverage": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["shadow", "paper", "live"]
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated"]
    },
    "assumptions": {
      "type": "object",
      "properties": {
        "feeBps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "slippageBps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "marketImpactBps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "partialFillRateBps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "partialFillPenaltyBps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "financingCostBpsPerDay": {
          "type": "string",
          "pattern": "^-?\\d+(?:\\.\\d+)?$"
        }
      },
      "required": [
        "feeBps",
        "slippageBps",
        "marketImpactBps",
        "partialFillRateBps",
        "partialFillPenaltyBps"
      ],
      "additionalProperties": false
    },
    "calibration": {
      "type": "object",
      "properties": {
        "calibrationId": {
          "type": "string",
          "minLength": 1
        },
        "methodology": {
          "type": "string",
          "minLength": 1
        },
        "sampleStartAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "sampleEndAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "sampleCount": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "confidenceBps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "referenceNotionalUsd": {
          "type": "string",
          "pattern": "^\\d+(?:\\.\\d+)?$"
        },
        "tags": {
          "maxItems": 16,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "calibrationId",
        "methodology",
        "sampleStartAt",
        "sampleEndAt",
        "sampleCount",
        "confidenceBps",
        "referenceNotionalUsd",
        "tags"
      ],
      "additionalProperties": false
    },
    "driftGuard": {
      "type": "object",
      "properties": {
        "maxCostDriftBps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "maxLatencyDriftMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "maxReconciliationDriftUsd": {
          "type": "string",
          "pattern": "^\\d+(?:\\.\\d+)?$"
        }
      },
      "required": [
        "maxCostDriftBps",
        "maxLatencyDriftMs",
        "maxReconciliationDriftUsd"
      ],
      "additionalProperties": false
    },
    "latencyProfile": {
      "type": "object",
      "properties": {
        "expectedQuoteMs": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "expectedSubmitMs": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "expectedSettlementMs": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "expectedQuoteMs",
        "expectedSubmitMs",
        "expectedSettlementMs"
      ],
      "additionalProperties": false
    },
    "datasetSnapshots": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "datasetId": {
            "type": "string",
            "minLength": 1
          },
          "snapshotId": {
            "type": "string",
            "minLength": 1
          },
          "capturedAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
          },
          "uri": {
            "type": "string",
            "minLength": 1
          },
          "contentDigest": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["datasetId", "snapshotId", "capturedAt"],
        "additionalProperties": false
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "tags": {
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schemaVersion",
    "modelId",
    "venueKey",
    "marketType",
    "pairSymbol",
    "assetKeys",
    "modeCoverage",
    "status",
    "assumptions",
    "calibration",
    "driftGuard",
    "latencyProfile",
    "datasetSnapshots",
    "createdAt",
    "updatedAt",
    "tags"
  ],
  "additionalProperties": false
}
