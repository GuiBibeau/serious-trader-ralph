{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/runtime/v1/strategy_lab_readiness_canary_run",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "subjectKind": {
      "type": "string",
      "enum": ["strategy", "venue", "asset"]
    },
    "subjectKey": {
      "type": "string",
      "minLength": 1
    },
    "venueKey": {
      "type": "string",
      "minLength": 1
    },
    "assetKey": {
      "type": "string",
      "minLength": 1
    },
    "pairSymbol": {
      "type": "string",
      "minLength": 1
    },
    "adapterKey": {
      "type": "string",
      "minLength": 1
    },
    "triggerSource": {
      "type": "string",
      "enum": ["manual", "promotion"]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "success", "blocked", "failed", "disabled", "skipped"]
    },
    "inputMint": {
      "type": "string",
      "minLength": 32,
      "maxLength": 64
    },
    "outputMint": {
      "type": "string",
      "minLength": 32,
      "maxLength": 64
    },
    "targetNotionalUsd": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?$"
    },
    "walletId": {
      "type": "string",
      "minLength": 1
    },
    "walletAddress": {
      "type": "string",
      "minLength": 1
    },
    "receiptId": {
      "type": "string",
      "minLength": 1
    },
    "signature": {
      "type": "string",
      "minLength": 1
    },
    "errorCode": {
      "type": "string",
      "minLength": 1
    },
    "errorMessage": {
      "type": "string",
      "minLength": 1
    },
    "reconciliation": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "not_attempted"]
        },
        "actualOutputAtomic": {
          "type": "string",
          "pattern": "^-?\\d+(?:\\.\\d+)?$"
        },
        "minExpectedOutAtomic": {
          "type": "string",
          "pattern": "^-?\\d+(?:\\.\\d+)?$"
        },
        "notes": {
          "maxItems": 16,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": ["status"],
      "additionalProperties": false
    },
    "evidenceRefs": {
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["kind", "ref"],
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "startedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    }
  },
  "required": [
    "schemaVersion",
    "runId",
    "subjectKind",
    "subjectKey",
    "venueKey",
    "assetKey",
    "pairSymbol",
    "adapterKey",
    "triggerSource",
    "status",
    "inputMint",
    "outputMint",
    "targetNotionalUsd",
    "evidenceRefs",
    "startedAt"
  ],
  "additionalProperties": false
}
