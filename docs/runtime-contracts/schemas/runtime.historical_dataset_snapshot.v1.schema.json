{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/runtime/v1/historical_dataset_snapshot",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "datasetId": {
      "type": "string",
      "minLength": 1
    },
    "snapshotId": {
      "type": "string",
      "minLength": 1
    },
    "datasetKind": {
      "type": "string",
      "enum": [
        "trades",
        "bars",
        "order_book_l2",
        "funding_rates",
        "borrow_rates",
        "reference_metadata",
        "market_events",
        "slot_events"
      ]
    },
    "normalizationKind": {
      "type": "string",
      "enum": ["raw", "normalized", "aggregated", "replay_ready"]
    },
    "format": {
      "type": "string",
      "enum": ["json", "jsonl", "parquet", "csv", "fixture_json"]
    },
    "retentionClass": {
      "type": "string",
      "enum": ["seed", "research", "production"]
    },
    "capturedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "coverageStartAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "coverageEndAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "rowCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "venueKeys": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assetKeys": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pairSymbols": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "chainKeys": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "uri": {
      "type": "string",
      "minLength": 1
    },
    "contentDigest": {
      "type": "string",
      "minLength": 1
    },
    "compression": {
      "type": "string",
      "minLength": 1
    },
    "timeBucketSeconds": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "provenance": {
      "type": "object",
      "properties": {
        "acquisitionKind": {
          "type": "string",
          "enum": [
            "exchange_export",
            "rpc_archive",
            "research_fixture",
            "manual_import",
            "derived"
          ]
        },
        "collectedFrom": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "collectedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "generator": {
          "type": "string",
          "minLength": 1
        },
        "generatorRevision": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["acquisitionKind", "collectedFrom", "collectedAt"],
      "additionalProperties": false
    },
    "samplingNotes": {
      "type": "string",
      "minLength": 1
    },
    "compactionNotes": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schemaVersion",
    "datasetId",
    "snapshotId",
    "datasetKind",
    "normalizationKind",
    "format",
    "retentionClass",
    "capturedAt",
    "coverageStartAt",
    "coverageEndAt",
    "rowCount",
    "venueKeys",
    "assetKeys",
    "pairSymbols",
    "chainKeys",
    "uri",
    "contentDigest",
    "provenance",
    "tags"
  ],
  "additionalProperties": false
}
