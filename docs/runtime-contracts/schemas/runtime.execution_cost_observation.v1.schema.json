{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/runtime/v1/execution_cost_observation",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "observationId": {
      "type": "string",
      "minLength": 1
    },
    "modelId": {
      "type": "string",
      "minLength": 1
    },
    "deploymentId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "receiptId": {
      "type": "string",
      "minLength": 1
    },
    "venueKey": {
      "type": "string",
      "minLength": 1
    },
    "marketType": {
      "type": "string",
      "enum": ["spot", "perp", "options"]
    },
    "pairSymbol": {
      "type": "string",
      "minLength": 1
    },
    "assetKeys": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mode": {
      "type": "string",
      "enum": ["shadow", "paper", "live"]
    },
    "observedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "evaluatedNotionalUsd": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?$"
    },
    "modeledTotalCostUsd": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?$"
    },
    "observedTotalCostUsd": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?$"
    },
    "costDriftUsd": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?$"
    },
    "costDriftBps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "expectedEndToEndLatencyMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "observedEndToEndLatencyMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "latencyDriftMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "reconciliationStatus": {
      "type": "string",
      "enum": ["passed", "needs_manual_review", "failed"]
    },
    "reconciliationDriftUsd": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?$"
    },
    "tags": {
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schemaVersion",
    "observationId",
    "modelId",
    "deploymentId",
    "runId",
    "receiptId",
    "venueKey",
    "marketType",
    "pairSymbol",
    "assetKeys",
    "mode",
    "observedAt",
    "evaluatedNotionalUsd",
    "modeledTotalCostUsd",
    "observedTotalCostUsd",
    "costDriftUsd",
    "costDriftBps",
    "expectedEndToEndLatencyMs",
    "observedEndToEndLatencyMs",
    "latencyDriftMs",
    "reconciliationStatus",
    "reconciliationDriftUsd",
    "tags"
  ],
  "additionalProperties": false
}
