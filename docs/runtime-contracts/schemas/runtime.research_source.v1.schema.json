{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/runtime/v1/research_source",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "sourceId": {
      "type": "string",
      "minLength": 1
    },
    "sourceKind": {
      "type": "string",
      "enum": [
        "paper",
        "article",
        "repository",
        "dataset",
        "notebook",
        "internal_note",
        "market_report"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "retrievedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "contentDigest": {
      "type": "string",
      "minLength": 1
    },
    "venueKeys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assetKeys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tags": {
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "schemaVersion",
    "sourceId",
    "sourceKind",
    "title",
    "url",
    "authors",
    "retrievedAt",
    "contentDigest",
    "venueKeys",
    "assetKeys",
    "tags"
  ],
  "additionalProperties": false
}
