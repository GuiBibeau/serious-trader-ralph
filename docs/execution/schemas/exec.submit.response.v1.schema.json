{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trader-ralph.com/schemas/exec.submit.response.v1.schema.json",
  "title": "ExecSubmitResponseV1",
  "type": "object",
  "required": ["ok", "requestId", "status", "poll"],
  "additionalProperties": false,
  "properties": {
    "ok": { "const": true },
    "requestId": {
      "type": "string",
      "pattern": "^execreq_[A-Za-z0-9_-]{8,}$"
    },
    "status": {
      "type": "object",
      "required": ["state", "terminal", "updatedAt"],
      "additionalProperties": false,
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "received",
            "validated",
            "queued",
            "dispatched",
            "landed",
            "finalized",
            "failed",
            "expired"
          ]
        },
        "terminal": { "type": "boolean" },
        "updatedAt": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T"
        }
      }
    },
    "poll": {
      "type": "object",
      "required": ["statusUrl", "receiptUrl"],
      "additionalProperties": false,
      "properties": {
        "statusUrl": { "type": "string", "pattern": "^/api/x402/exec/status/" },
        "receiptUrl": {
          "type": "string",
          "pattern": "^/api/x402/exec/receipt/"
        }
      }
    }
  }
}
